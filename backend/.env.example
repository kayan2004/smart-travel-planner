APP_NAME=Smart Travel Assistant API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
POSTGRES_DB=smart_travel_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smart_travel_assistant
DATABASE_ECHO=false
JWT_SECRET_KEY=change-this-development-secret-to-32-plus-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
RAG_EMBEDDING_BATCH_SIZE=32
RAG_EMBEDDING_MAX_REQUEST_TOKENS=10000
RAG_ESTIMATED_CHARS_PER_TOKEN=4
VOYAGE_API_KEY=pa-your-voyage-api-key-here
VOYAGE_API_BASE_URL=https://api.voyageai.com/v1
VOYAGE_EMBEDDING_MODEL=voyage-4-lite
VOYAGE_EMBEDDING_DIMENSION=1024
VOYAGE_TIMEOUT_SECONDS=30
VOYAGE_REQUESTS_PER_MINUTE=3
VOYAGE_MAX_RETRIES=3
LLM_PROVIDER=gemini
# Kept configured but unused while LLM_PROVIDER=gemini - flip the value above
# to switch back, no code changes needed.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_API_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_VERSION=2023-06-01
ANTHROPIC_FAST_MODEL=claude-3-5-haiku-latest
ANTHROPIC_STRONG_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=700
ANTHROPIC_TEMPERATURE=0.2
# Generate a *restricted* API key (scoped to the Generative Language API) at
# https://aistudio.google.com/apikey - Google phases out unrestricted keys during 2026.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_FAST_MODEL=gemini-3.1-flash-lite
GEMINI_STRONG_MODEL=gemini-3.1-pro
GEMINI_MAX_TOKENS=700
GEMINI_TEMPERATURE=0.2
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook
DISCORD_WEBHOOK_USERNAME=Smart Travel Assistant
DISCORD_WEBHOOK_TIMEOUT_SECONDS=15
DESTINATION_SEED_MANIFEST_PATH=data/destination_seed_manifest.json
DESTINATION_EMBEDDING_VERSION=v1
DESTINATION_FETCH_TIMEOUT_SECONDS=20
DESTINATION_MAX_RETRIES=3
DESTINATION_RETRY_BACKOFF_SECONDS=2
# Free signup at https://opentripmap.io/product - leave blank to skip the
# POI-enrichment step (ingestion degrades gracefully without it).
OPENTRIPMAP_API_KEY=
OPENTRIPMAP_BASE_URL=https://api.opentripmap.com/0.1/en
OPENTRIPMAP_RADIUS_METERS=20000
OPENTRIPMAP_POI_LIMIT=100
