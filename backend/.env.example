POSTGRES_DB=ground_trip
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ground_trip
# Defaults to false (secure-by-default) - set true for local dev if you want
# full tracebacks in error responses. Never set true in a real deployment.
APP_DEBUG=true
JWT_SECRET_KEY=change-this-development-secret-to-32-plus-chars
# The exact origin (scheme+host+port, no trailing slash) the frontend is
# served from - CORS rejects every other origin. docker-compose.yaml
# overrides this to http://localhost:5173 for local dev; a real deploy
# needs it set to the frontend's actual public URL (e.g.
# https://your-frontend.up.railway.app), or login/API calls from the
# frontend will fail with a CORS error.
FRONTEND_ORIGIN=http://localhost:5173
VOYAGE_API_KEY=pa-your-voyage-api-key-here
# Kept configured but unused while the default provider (gemini) is active -
# set LLM_PROVIDER=anthropic to switch, no code changes needed. Model name is
# not env-configurable - see app/core/config.py's anthropic_model/gemini_model
# fields (a deliberate cost/quality decision, changed via code review, not a
# runtime toggle).
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Generate a *restricted* API key (scoped to the Generative Language API) at
# https://aistudio.google.com/apikey - Google phases out unrestricted keys during 2026.
GEMINI_API_KEY=your-gemini-api-key-here
# Free signup at https://opentripmap.io/product - leave blank to skip the
# POI-enrichment step (ingestion degrades gracefully without it).
OPENTRIPMAP_API_KEY=YOUR-opentripmap-api-key-here
